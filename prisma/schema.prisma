generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String
  phone     String
  company   String
  message   String
  createdAt DateTime @default(now())
}
