generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String
  phone     String
  company   String
  message   String
  createdAt DateTime @default(now())
}
